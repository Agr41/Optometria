<!DOCTYPE html>
<html lang="{{lng}}">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0-beta3/css/all.min.css">
<link href="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/css/bootstrap.min.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.1.3/dist/js/bootstrap.bundle.min.js"></script>

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{t 'place_autocomplete_title'}}</title>
    <link rel="stylesheet" href="/node_modules/bootstrap/dist/css/bootstrap.css">
    <link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet"
        href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
    <link rel="stylesheet" href="/public/stylesheets/style.css">
    <style>
        .main-container {
            display: flex;
            flex-direction: row;
            justify-content: flex-start;
            align-items: flex-start;
            gap: 20px; /* Reducir el gap para acercar los contenedores */
            margin-top: 20px;
            margin-left: -100px; /* Asegurar que el contenedor principal esté alineado a la izquierda */
        }

        .roles-container {
            background-color: #FFFFFF;
            border-radius: 8px;
            padding: 16px;
            max-width: 300px;
            margin-left: -10px; /* Reducir el margen izquierdo */
            margin-top: -20px; /* Ajustar el margen superior */
        }

        .role-title {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 16px;
            font-size: 1.5rem;
            color: #333;
        }

        .role-item {
            background-color: #FFFFFF;
            border-radius: 4px;
            padding: 8px 16px;
            margin-bottom: 8px;
            font-size: 1rem;
            color: #555;
            margin-top: 20px;
        }

        .add-role-btn {
            margin-right: 50px;
            border: none;
            background: none;
            color: #000;
            padding: 8px;
            font-size: 3rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .role-item-black {
            color: #000000;
            font-weight: bold;
        }

        .role-item-placeholder {
            color: #a0a0a0;
        }

        .roles-container,
        .roles-container2 {
            min-width: 300px;
            max-width: 300px;
        }

        .roles-container2 {
            background-color: #FFFFFF;
            border-radius: 8px;
            padding: 16px;
            max-width: 500px; /* Ajustado */
            margin-left: 200px; /* Ajustado */
            margin-top: -20px; /* Ajustado */
            color: #333;
            font-weight: bold;
        }

        .role-title2 {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 24px;
            font-size: 1.5rem;
            color: #333;
        }

        .role-item2 {
            background-color: #FFFFFF;
            border-radius: 4px;
            padding: 8px 16px;
            margin-bottom: 24px;
            font-size: 1rem;
            color: #555;
            margin-top: 15px;
        }

        .add-role-btn2 {
            border: none;
            border-radius: 50%;
            color: #fff;
            padding: 8px;
            font-size: 1.5rem;
            cursor: pointer;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .role-input-container {
            display: flex;
            align-items: center;
            justify-content: space-between;
            margin-bottom: 16px;
        }

        .role-input {
            flex-grow: 2;
            margin-right: 8px;
            padding: 8px;
            border: 1px solid #ccc;
            border-radius: 4px;
            min-width: 260px;
        }

        .role-input::placeholder {
            font-weight: bold;
        }

        .option-btn {
            border: none;
            background: none;
            cursor: pointer;
            margin-left: 8px;
            display: inline-flex;
            align-items: center;
            justify-content: center;
        }

        .roles-permissions-container {
            display: flex;
            flex-direction: column;
            align-items: flex-start;
            gap: 40px;
        }

        .titles-container {
            display: flex;
            justify-content: space-between;
            width: 75%;
        }

        .module-title {
            text-align: right;
            margin-right: 30px;
        }

        .permissions-title {
            text-align: left;
        }

        .module {
            text-align: left;
        }

        .module-row {
            position: relative;
        }

        .module-name {
            flex-basis: 20%;
            font-weight: bold;
            margin-left: 20px;
            font-size: 0.9rem;
        }

        .module-permissions {
            flex: 2;
            display: flex;
            justify-content: flex-start;
            gap: 0.5rem;
        }

        .permissions {
            display: flex;
            justify-content: flex-start;
            gap: 0.5rem;
            padding-left: 20px;
            margin-left: 0px; /* Ajustado */
            margin-top: 0px; /* Ajustado */
        }

        .pi {
            font-size: 1.2rem;
        }

        .p-button {
            background-color: #007bff;
            border: none;
        }

        .p-button .pi {
            color: white;
        }

        .p-button-rounded {
            border-radius: 4px;
            width: 2.5em; /* Ajustado */
            height: 2.5em; /* Ajustado */
            line-height: 1em;
            margin-right: 2em;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .p-button .fas {
            font-size: 2.5em; /* Ajustado */
            color: white; /* Ajustado */
        }

        .p-button-gray {
            background-color: #adadad;
        }

        .p-button-help,
        .p-button-success,
        .p-button-warning,
        .p-button-danger {
            background-color: #007bff;
        }

        .col-lg-8.mx-auto.p-4.py-md-5 {
            max-width: 90%; /* Ajustado */
            padding: 2rem; /* Ajusta el padding si es necesario */
        }
    </style>
</head>

