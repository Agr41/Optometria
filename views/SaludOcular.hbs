<script>
document.addEventListener('DOMContentLoaded', function() {
  const validateInput = (input, min, max, step, feedbackId) => {
    const feedback = document.getElementById(feedbackId);
    const value = parseFloat(input.value);
    if (input.required && !input.value) {
      input.classList.add('is-invalid');
      feedback.textContent = '{{t "validation.required"}}';
    } else if (isNaN(value) || value < min || value > max) {
      input.classList.add('is-invalid');
      feedback.textContent = `{{t "validation.range" min="${min}" max="${max}"}}`;
    } else if ((value - min) % step !== 0) {
      input.classList.add('is-invalid');
      feedback.textContent = `{{t "validation.step" step="${step}"}}`;
    } else {
      input.classList.remove('is-invalid');
      feedback.textContent = '';
    }
  };

  const inputs = [
    // Campos de OFTALMOSCOPÍA OD
    { id: 'ColorDeRetinaOD', min: -1, max: 1, step: 0.25 },
    { id: 'ExcavacionOD', min: -1, max: 1, step: 0.25 },
    { id: 'RelacionAVOD', min: 0, max: 100, step: 1 },
    { id: 'ISNTOD', min: 0, max: 100, step: 1 },
    { id: 'ReflejoFovealOD', min: 0, max: 100, step: 1 },
    { id: 'DiametroOD', min: 0, max: 100, step: 1 },
    
    // Campos de OFTALMOSCOPÍA OI
    { id: 'ColorDeRetinaOI', min: -1, max: 1, step: 0.25 },
    { id: 'ExcavacionOI', min: -1, max: 1, step: 0.25 },
    { id: 'RelacionAVOI', min: 0, max: 100, step: 1 },
    { id: 'ISNTOI', min: 0, max: 100, step: 1 },
    { id: 'ReflejoFovealOI', min: 0, max: 100, step: 1 },
    { id: 'DiametroOI', min: 0, max: 100, step: 1 },

    // Campos de QUERATOMETRÍAS
    { id: 'QUERATOMETRIASOD', min: 30, max: 50, step: 0.25 },
    { id: 'QUERATOMETRIASOI', min: 30, max: 50, step: 0.25 },
    
    // Campos de RETINOSCOPÍA ESTÁTICA
    { id: 'REOD', min: 0, max: 100, step: 1 },
    { id: 'REODAV', min: 0, max: 100, step: 1 },
    { id: 'REOI', min: 0, max: 100, step: 1 },
    { id: 'REOIAV', min: 0, max: 100, step: 1 },
    
    // Campos de DINÁMICA
    { id: 'DINAMICAOD', min: 0, max: 100, step: 1 },
    { id: 'DINAMICAAVOD', min: 0, max: 100, step: 1 },
    { id: 'DINAMICAOI', min: 0, max: 100, step: 1 },
    { id: 'DINAMICAAVOI', min: 0, max: 100, step: 1 },

    // Campos de MOHINDRA
    { id: 'MOHINDRAOD', min: 0, max: 100, step: 1 },
    { id: 'MOHINDRAAVOD', min: 0, max: 100, step: 1 },
    { id: 'MOHINDRAOI', min: 0, max: 100, step: 1 },
    { id: 'MOHINDRAAVOI', min: 0, max: 100, step: 1 },

    // Campos de EXÁMEN SUBJETIVO
    { id: 'EXAMENSUBJETIVOOD', min: 0, max: 100, step: 1 },
    { id: 'EXAMENSUBJETIVOAVOD', min: 0, max: 100, step: 1 },
    { id: 'EXAMENSUBJETIVOOI', min: 0, max: 100, step: 1 },
    { id: 'EXAMENSUBJETIVOAVOI', min: 0, max: 100, step: 1 },
    
    // Campos de AFINACIONES y TIPO DE TEST
    { id: 'AFINACIONES', min: 0, max: 100, step: 1 },
    { id: 'TIPODETEST', min: 0, max: 100, step: 1 }
  ];

  inputs.forEach(input => {
    const element = document.querySelector(`input[name="CamposDeFormulario[${input.id}]"]`);
    element.addEventListener('input', () => validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`));
    element.addEventListener('blur', () => validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`));
  });

  document.getElementById('formulario').addEventListener('submit', function(event) {
    let isValid = true;
    inputs.forEach(input => {
      const element = document.querySelector(`input[name="CamposDeFormulario[${input.id}]"]`);
      validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`);
      if (element.classList.contains('is-invalid')) {
        isValid = false;
        element.scrollIntoView({ behavior: "smooth" });
        element.focus();
      }
    });
    if (!isValid) {
      event.preventDefault();
    }
  });
});
</script>


