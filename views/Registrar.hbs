<style>
  body {
    background-color: #f2f2f2;
  }
  form {
    margin: 20px;
    padding: 20px;
    background-color: #f2f2f2;
    border-radius: 10px;
  }
  label {
    display: block;
    margin-bottom: 10px;
    font-weight: bold;
    color: #333;
  }
  input[type=text], input[type=password] {
    padding: 8px;
    margin-bottom: 10px;
    width: 100%;
    border: 1px solid #ccc;
    border-radius: 4px;
    box-sizing: border-box;
  }
  button[type=submit] {
    background-color: #12372A;
    color: white;
    padding: 12px 20px;
    border: none;
    border-radius: 4px;
    cursor: pointer;
    font-size: 16px;
    margin-top: 10px;
  }
  button[type=submit]:hover {
    background-color: #12372A;
  }
</style>



<!DOCTYPE html>
<html lang="{{lng}}">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{{t 'register_user'}}</title>
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
    <link rel="stylesheet" href="/public/stylesheets/style.css">
</head>
<body class="d-flex flex-column min-vh-100">
    <div class="container-fluid">
        <div class="row">
            <div class="col-sm-12 col-md-3 col-lg-2 px-0">
                <!-- Sidebar -->
                {{> sidebar}}
            </div>
            <div class="col-sm-12 col-md-9 col-lg-10 px-0">
                <div class="col-lg-8 mx-auto p-4 py-md-5">
                    <header class="d-flex align-items-center pb-3 mb-5 border-bottom">
                        <h2>{{t 'enter_user_data'}}</h2>
                    </header>
                    <main>
                        <div class="modal-content rounded-4 shadow">
                            <div class="modal-body p-5 border border-2 border-dark rounded">
                                <div class="container">
                                    <form method="POST" action="/RegistrarsePost">
                                        <div class="row g-3">
                                            <div class="col-sm-12">
                                                <label class="form-label">{{t 'institutional_email'}}:</label>
                                                <input type="text" class="form-control" name="username" required>
                                            </div>
                                            <div class="col-sm-12">
                                                <label class="form-label">{{t 'password'}}:</label>
                                                <input type="password" class="form-control" name="password" required>
                                            </div>
                                            <div class="col-sm-4">
                                                <label class="form-label">{{t 'first_name'}}:</label>
                                                <input type="text" class="form-control" name="Nombre" required>
                                            </div>
                                            <div class="col-sm-4">
                                                <label class="form-label">{{t 'last_name_father'}}:</label>
                                                <input type="text" class="form-control" name="ApellidoPaterno" required>
                                            </div>
                                            <div class="col-sm-4">
                                                <label class="form-label">{{t 'last_name_mother'}}:</label>
                                                <input type="text" class="form-control" name="ApellidoMaterno">
                                            </div>
                                            <label>{{t 'role'}}:</label>
                                            <select name="role" id="role" class="form-select">
                                                <option value="admin">{{t 'admin'}}</option>
                                                <option value="alumno">{{t 'student'}}</option>
                                                <option value="cliente">{{t 'client'}}</option>
                                            </select>
                                            <button type="submit" class="btn btn-primary">{{t 'register_user_button'}}</button>
                                        </div>
                                    </form>
                                </div>
                            </div>
                        </div>
                    </main>
                </div>
            </div>
        </div>
    </div>
    {{> footer}}
</body>
</html>
