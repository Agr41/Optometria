<script>
document.addEventListener('DOMContentLoaded', function() {
  const validateInput = (input, min, max, step, feedbackId) => {
    const feedback = document.getElementById(feedbackId);
    const value = parseFloat(input.value);
    if (input.required && !input.value) {
      input.classList.add('is-invalid');
      feedback.textContent = 'Este campo es requerido.';
    } else if (isNaN(value) || value < min || value > max) {
      input.classList.add('is-invalid');
      feedback.textContent = `El valor debe estar entre ${min} y ${max}.`;
    } else if ((value - min) % step !== 0) {
      input.classList.add('is-invalid');
      feedback.textContent = `El valor debe ser un múltiplo de ${step}.`;
    } else {
      input.classList.remove('is-invalid');
      feedback.textContent = '';
    }
  };

  const inputs = [
    // Pruebas funcionales
    { id: 'FLL', min: -1, max: 1, step: 0.25 },
    { id: 'FVL', min: -1, max: 1, step: 0.25 },
    { id: 'VVL', min: 0, max: 100, step: 1 },
    { id: 'BNL', min: 0, max: 100, step: 1 },
    { id: 'CCF', min: 0, max: 100, step: 1 },
    { id: 'ARN', min: 0, max: 100, step: 1 },
    { id: 'ARP', min: 0, max: 100, step: 1 },
    { id: 'ADD', min: 0, max: 100, step: 1 },
    { id: 'FLC', min: 0, max: 100, step: 1 },
    { id: 'FLC+1', min: 0, max: 100, step: 1 },
    { id: 'AC/A', min: 0, max: 100, step: 1 },
    { id: 'FVC', min: 0, max: 100, step: 1 },
    { id: 'VVC', min: 0, max: 100, step: 1 },
    { id: 'BNC', min: 0, max: 100, step: 1 },
    { id: 'BTC', min: 0, max: 100, step: 1 },
    { id: 'PPCNA', min: 0, max: 100, step: 1 },
    { id: 'PPCA', min: 0, max: 100, step: 1 },

    // OD y OI
    { id: 'FLEXOD', min: 0, max: 100, step: 1 },
    { id: 'FLEXOI', min: 0, max: 100, step: 1 },
    { id: 'AAOD', min: 0, max: 100, step: 1 },
    { id: 'AAOI', min: 0, max: 100, step: 1 },
    { id: 'HIRSCHBERGOD', min: 0, max: 100, step: 1 },
    { id: 'HIRSCHBERGOI', min: 0, max: 100, step: 1 },

    // Lejos y Cerca
    { id: 'COVERLejos', min: 0, max: 100, step: 1 },
    { id: 'COVERCerca', min: 0, max: 100, step: 1 }
  ];

  inputs.forEach(input => {
    const element = document.querySelector(`input[name="CamposDeFormulario[${input.id}]"]`);
    element.addEventListener('input', () => validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`));
    element.addEventListener('blur', () => validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`));
  });

  document.getElementById('formulario').addEventListener('submit', function(event) {
    let isValid = true;
    inputs.forEach(input => {
      const element = document.querySelector(`input[name="CamposDeFormulario[${input.id}]"]`);
      validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`);
      if (element.classList.contains('is-invalid')) {
        isValid = false;
        element.scrollIntoView({ behavior: "smooth" });
        element.focus();
      }
    });
    if (!isValid) {
      event.preventDefault();
    }
  });
});
</script>

