{{#if ingles}}

<link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@20..48,100..700,0..1,-50..200" />
<link rel="stylesheet" href="/public/stylesheets/style.css">
<link rel="stylesheet"
    href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:opsz,wght,FILL,GRAD@48,400,0,0" />
<link href="https://fonts.googleapis.com/css2?family=Roboto:wght@400;700&display=swap" rel="stylesheet">
<link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;700&display=swap" rel="stylesheet">

<div class="col-lg-10 mx-auto p-4 py-md-5">

    <header class="d-flex align-items-center pb-3 mb-5 border-bottom ">
        Welcome {{nombre}}
    </header>

    <body class="d-flex flex-column min-vh-100">
        <main>


            <div class="modal-content rounded-4 shadow">


                <div class="modal-body p-4 border border-2 border-dark rounded">

                    <div class="container text-center">

                        <div class="container text-center">
                            <div class="row align-items-center">
                                <div class="col">
                                    <a href="/form">
                                        <div class="modal-body p-4 border border-2 border-dark rounded btn btn-outline-success"
                                            style="width: 150px; margin-bottom: 15px"
                                            onclick="window.location.href = '/form'">

                                            <div class="col ">
                                                <span class="material-symbols-outlined">
                                                    settings_accessibility
                                                </span>
                                            </div>
                                            <div class="w-100 d-none d-md-block"></div>

                                            <div class="col ">
                                                New patient
                                            </div>

                                            </span>
                                        </div>
                                    </a>
                                </div>
                                <div class="col">

                                    <div class="modal-body p-4 border border-2 border-dark rounded btn btn-outline-success"
                                        style="width: 150px; margin-bottom: 15px"
                                        onclick="window.location.href = '/test'">

                                        <div class="col ">
                                            <span class="material-symbols-outlined">
                                                Quiz
                                            </span>
                                        </div>
                                        <div class="w-100 d-none d-md-block"></div>

                                        <div class="col ">
                                            Screening campaigns
                                        </div>

                                    </div>

                                </div>
                                <div class="col">

                                    <div class="modal-body p-4 border border-2 border-dark rounded btn btn-outline-success"
                                        style="width: 150px; margin-bottom: 15px"
                                        onclick="window.location.href = '/menu_clinica'">

                                        <div class="col ">
                                            <span class="material-symbols-outlined">
                                                home_health
                                            </span>
                                        </div>
                                        <div class="w-100 d-none d-md-block"></div>

                                        <div class="col ">
                                            Clinic
                                        </div>

                                    </div>

                                </div>
                                <div class="w-100"></div>
                                <div class="col ">

                                    <a href="/PanelPacientes">
                                        <div class="modal-body p-4 border border-2 border-dark rounded btn btn-outline-success"
                                            style="width: 150px; margin-bottom: 15px">

                                            <div class="col ">
                                                <span class="material-symbols-outlined">
                                                    Search
                                                </span>
                                            </div>
                                            <div class="w-100 d-none d-md-block"></div>

                                            <div class="col">
                                                See patients
                                            </div>

                                        </div>
                                    </a>


                                </div>
                                <div class="col ">

                                    <a href="/graficas">
                                        <div class="modal-body p-4 border border-2 border-dark rounded btn btn-outline-success"
                                            style="width: 150px; margin-bottom: 15px">

                                            <div class="col ">
                                                <span class="material-symbols-outlined">
                                                    bar_chart
                                                </span>
                                            </div>
                                            <div class="w-100 d-none d-md-block"></div>

                                            <div class="col">
                                                Graphs
                                            </div>

                                        </div>
                                    </a>


                                </div>
                                <div class="col">
                                    <a href="/configuracion">
                                        <div class="modal-body p-4 border border-2 border-dark rounded btn btn-outline-success"
                                            style="width: 150px; margin-bottom: 15px">
                                            <div class="col ">
                                                <span class="material-symbols-outlined">
                                                    Settings
                                                </span>
                                            </div>
                                            <div class="w-100 d-none d-md-block"></div>

                                            <div class="col ">
                                                Settings
                                            </div>


                                        </div>
                                    </a>

                                </div>
                            </div>
                        </div>



                    </div>

                </div>
            </div>
        </main>


    </body>


</div>




{{>footer}}


