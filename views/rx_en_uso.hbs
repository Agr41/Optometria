<!-- JavaScript -->
<script>
document.addEventListener('DOMContentLoaded', function() {
  const validateInput = (input, min, max, step, feedbackId) => {
    const feedback = document.getElementById(feedbackId);
    if (input.type === 'number') {
      const value = parseFloat(input.value);
      if (input.required && !input.value) {
        input.classList.add('is-invalid');
        feedback.textContent = 'Este campo es requerido.';
      } else if (isNaN(value) || value < min || (max !== Infinity && value > max)) {
        input.classList.add('is-invalid');
        feedback.textContent = `El valor debe estar entre ${min} y ${max}.`;
      } else if ((value - min) % step !== 0) {
        input.classList.add('is-invalid');
        feedback.textContent = `El valor debe ser un múltiplo de ${step}.`;
      } else {
        input.classList.remove('is-invalid');
        feedback.textContent = '';
      }
    } else if (input.type === 'text') {
      if (input.required && !input.value) {
        input.classList.add('is-invalid');
        feedback.textContent = 'Este campo es requerido.';
      } else {
        input.classList.remove('is-invalid');
        feedback.textContent = '';
      }
    }
  };

  const inputs = [
    // Existing inputs
    { id: 'esferaOD', min: -30, max: 20, step: 0.25 },
    { id: 'esferaOI', min: -30, max: 20, step: 0.25 },
    { id: 'cilindroOD', min: -10, max: 0, step: 0.25 },
    { id: 'cilindroOI', min: -10, max: 0, step: 0.25 },
    { id: 'ejeOD', min: 0, max: 180, step: 1 },
    { id: 'ejeOI', min: 0, max: 180, step: 1 },
    { id: 'dip', min: 20, max: 75, step: 1 },
    { id: 'adicion', min: 0.5, max: 3.5, step: 0.25 },
    { id: 'pa1', min: 0, max: Infinity, step: 1 },
    { id: 'pa2', min: 0, max: Infinity, step: 1 },
    { id: 'medGlucosa', min: 0, max: 100000, step: 1 }, // Updated step size to 1
    // Text inputs without min/max
    { id: 'DNPOD', min: 0, max: Infinity, step: 1 },
    { id: 'DNPOI', min: 0, max: Infinity, step: 1 },
    { id: 'molestiaComo', min: 0, max: Infinity, step: 1 },
    { id: 'molestiaAntiguedad', min: 0, max: Infinity, step: 1 },
    { id: 'observaciones', min: 0, max: Infinity, step: 1 },
    { id: 'antecendentes', min: 0, max: Infinity, step: 1 },
    { id: 'tratamientos', min: 0, max: Infinity, step: 1 }
  ];

  inputs.forEach(input => {
    const element = document.querySelector(`input[name="CamposDeFormulario[${input.id}]"]`);
    element.addEventListener('input', () => validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`));
    element.addEventListener('blur', () => validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`));
  });

  // Prevent form submission if there are invalid inputs
  document.getElementById('formulario').addEventListener('submit', function(event) {
    let isValid = true;
    inputs.forEach(input => {
      const element = document.querySelector(`input[name="CamposDeFormulario[${input.id}]"]`);
      validateInput(element, input.min, input.max, input.step, `${input.id}Feedback`);
      if (element.classList.contains('is-invalid')) {
        isValid = false;
        element.scrollIntoView({ behavior: "smooth" }); // Ensure the element is in view
        element.focus();
      }
    });
    if (!isValid) {
      event.preventDefault();
    }
  });
});

</script>





